{
  "kind": "collectionType",
  "collectionName": "operation_details",
  "info": {
    "singularName": "operation-detail",
    "pluralName": "operation-details",
    "displayName": "operationDetail"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "company": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::company.company",
      "inversedBy": "operation_detail"
    },
    "title": {
      "type": "string"
    },
    "year": {
      "type": "integer"
    },
    "month": {
      "type": "string"
    },
    "isPercentValue": {
      "type": "boolean",
      "default": false
    },
    "value": {
      "type": "float"
    }
  }
}
