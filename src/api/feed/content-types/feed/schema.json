{
  "kind": "collectionType",
  "collectionName": "feeds",
  "info": {
    "singularName": "feed",
    "pluralName": "feeds",
    "displayName": "Feed"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "SCREENER",
        "CAPSULE+",
        "IPO"
      ]
    },
    "tag": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::tag.tag"
    },
    "featuredImage": {
      "allowedTypes": [
        "images"
      ],
      "type": "media",
      "multiple": false,
      "required": true
    },
    "url": {
      "type": "string",
      "required": true
    },
    "industry": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::industry.industry"
    }
  }
}
