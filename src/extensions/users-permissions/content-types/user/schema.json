{
  "kind": "collectionType",
  "collectionName": "up_users",
  "info": {
    "name": "user",
    "description": "",
    "singularName": "user",
    "pluralName": "users",
    "displayName": "User"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "email": {
      "type": "email",
      "minLength": 6,
      "configurable": false,
      "required": true
    },
    "provider": {
      "type": "string",
      "configurable": false
    },
    "confirmationToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmed": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "blocked": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "role": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.role",
      "inversedBy": "users",
      "configurable": false
    },
    "image": {
      "type": "string"
    },
    "gender": {
      "type": "enumeration",
      "enum": [
        "male",
        "female",
        "prefer no to say"
      ]
    },
    "fullName": {
      "type": "string"
    },
    "dob": {
      "type": "date"
    },
    "profession": {
      "type": "string"
    },
    "googleId": {
      "type": "string"
    },
    "facebookId": {
      "type": "string"
    },
    "profileStatus": {
      "type": "string",
      "default": "pending"
    },
    "subscriptions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::subscription.subscription",
      "mappedBy": "userId"
    },
    "user_roles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-role.user-role"
    },
    "capsuleplus": {
      "type": "boolean",
      "default": false
    },
    "socketId": {
      "type": "string"
    }
  }
}
